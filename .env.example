# Copy this file to `.env` and fill in your real values.
# The `.env` file is git-ignored and must NEVER be committed.

# Required for the CLI client (lab-sentinel). The MCP server itself does NOT need this.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the default model.
OPENAI_MODEL=gpt-4o

# Optional: path to the SSH config used as inventory (defaults to ~/.ssh/config).
# SENTINEL_SSH_CONFIG=~/.ssh/config

# Optional: path to the group-definition file (defaults to ./.sentinel.yaml).
# SENTINEL_GROUPS_FILE=.sentinel.yaml
